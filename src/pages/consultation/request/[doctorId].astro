---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { getSessionUser } from "../../../lib/auth/session";
import { drizzle } from "drizzle-orm/d1";
import { eq } from "drizzle-orm";
import { users, doctorProfiles } from "../../../lib/db/schema";

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;
if (!sessionCookie || !env) return Astro.redirect("/auth/login");

const currentUser = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
if (!currentUser) return Astro.redirect("/auth/login");
if (currentUser.role !== "patient") return Astro.redirect("/dashboard/doctor");

const { doctorId } = Astro.params;
if (!doctorId) return Astro.redirect("/doctors");

const db = drizzle(env.DB);
const doctorUser = await db.select().from(users).where(eq(users.id, doctorId)).get();
const doctorProfile = await db.select().from(doctorProfiles).where(eq(doctorProfiles.userId, doctorId)).get();

if (!doctorUser || !doctorProfile) return Astro.redirect("/doctors");
if (!doctorProfile.isAvailable) return Astro.redirect(`/doctors/${doctorProfile.slug}`);
---

<DashboardLayout title={`Consult ${doctorUser.name} — MedConnect`} role="patient">
  <div class="max-w-2xl mx-auto">
    <a href={`/doctors/${doctorProfile.slug}`} class="flex items-center gap-1.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-text)] mb-6">
      ← Back to profile
    </a>

    <h1 class="text-2xl font-bold mb-1">Request Consultation</h1>
    <p class="text-[var(--color-muted)] text-sm mb-6">
      With <span class="font-medium text-[var(--color-text)]">{doctorUser.name}</span> · {doctorProfile.specialization}
      {doctorProfile.consultationFee != null && ` · ₹${doctorProfile.consultationFee}`}
    </p>

    {doctorProfile.terms && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 text-sm text-amber-900">
        <strong class="block mb-1">Doctor's terms:</strong>
        {doctorProfile.terms}
      </div>
    )}

    <form id="request-form" class="bg-white rounded-2xl border border-[var(--color-border)] p-6 space-y-5">
      <div>
        <label for="chief-complaint" class="block text-sm font-medium mb-1.5">
          Chief complaint <span class="text-[var(--color-danger)]">*</span>
        </label>
        <input
          id="chief-complaint"
          type="text"
          placeholder="Brief reason for consultation (e.g. Recurring headaches for 2 weeks)"
          required
          maxlength="500"
          class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
        />
      </div>

      <div>
        <label for="symptoms" class="block text-sm font-medium mb-1.5">Symptoms in detail</label>
        <textarea
          id="symptoms"
          rows="4"
          placeholder="Describe your symptoms in detail — severity, triggers, what makes it better or worse…"
          maxlength="2000"
          class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent resize-y"
        ></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="duration" class="block text-sm font-medium mb-1.5">Duration of symptoms</label>
          <input
            id="duration"
            type="text"
            placeholder="e.g. 3 days, 2 weeks"
            maxlength="200"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
          />
        </div>
        <div>
          <label for="existing" class="block text-sm font-medium mb-1.5">Existing conditions</label>
          <input
            id="existing"
            type="text"
            placeholder="e.g. Diabetes, Hypertension"
            maxlength="500"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
          />
        </div>
      </div>

      <div>
        <label for="medications" class="block text-sm font-medium mb-1.5">Current medications</label>
        <input
          id="medications"
          type="text"
          placeholder="e.g. Metformin 500mg, Amlodipine 5mg"
          maxlength="1000"
          class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
        />
      </div>

      <!-- File attachment -->
      <div>
        <label class="block text-sm font-medium mb-1.5">Attach reports / images <span class="text-[var(--color-muted)] font-normal">(optional)</span></label>
        <div id="drop-zone" class="border-2 border-dashed border-[var(--color-border)] rounded-xl p-6 text-center cursor-pointer hover:border-[var(--color-primary)] transition-colors">
          <svg class="w-8 h-8 text-[var(--color-muted)] mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.375 12.739l-7.693 7.693a4.5 4.5 0 01-6.364-6.364l10.94-10.94A3 3 0 1119.5 7.372L8.552 18.32m.009-.01l-.01.01m5.699-9.941l-7.81 7.81a1.5 1.5 0 002.112 2.13"/></svg>
          <p class="text-sm text-[var(--color-muted)]">Drag files here or <span class="text-[var(--color-primary)]">click to upload</span></p>
          <p class="text-xs text-[var(--color-muted)] mt-1">Images, PDFs, documents — max 20MB each</p>
          <input type="file" id="file-input" multiple accept="image/*,.pdf,.doc,.docx" class="hidden" />
        </div>
        <ul id="file-list" class="mt-2 space-y-1.5"></ul>
      </div>

      <p id="submit-error" class="text-sm text-[var(--color-danger)] hidden"></p>

      <button
        type="submit"
        id="submit-btn"
        class="w-full py-3 rounded-xl bg-[var(--color-primary)] text-white font-semibold hover:bg-[var(--color-primary-dark)] transition-colors disabled:opacity-60"
      >
        Send Consultation Request
      </button>
    </form>
  </div>
</DashboardLayout>

<script define:vars={{ doctorId }}>
  const fileInput = document.getElementById("file-input");
  const dropZone = document.getElementById("drop-zone");
  const fileList = document.getElementById("file-list");
  const submitBtn = document.getElementById("submit-btn");
  const submitError = document.getElementById("submit-error");

  let uploadedKeys = [];

  dropZone.addEventListener("click", () => fileInput.click());
  dropZone.addEventListener("dragover", (e) => { e.preventDefault(); dropZone.classList.add("border-[var(--color-primary)]"); });
  dropZone.addEventListener("dragleave", () => dropZone.classList.remove("border-[var(--color-primary)]"));
  dropZone.addEventListener("drop", (e) => { e.preventDefault(); handleFiles(e.dataTransfer.files); });
  fileInput.addEventListener("change", () => handleFiles(fileInput.files));

  async function handleFiles(files) {
    for (const file of files) {
      const li = document.createElement("li");
      li.className = "flex items-center gap-2 text-xs text-[var(--color-muted)] bg-[var(--color-bg)] px-3 py-2 rounded-lg";
      li.innerHTML = `<span class="flex-1 truncate">${file.name}</span><span class="shrink-0">Uploading…</span>`;
      fileList.appendChild(li);

      try {
        const fd = new FormData();
        fd.append("file", file);
        const res = await fetch("/api/upload", { method: "POST", body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error ?? "Upload failed");
        uploadedKeys.push(data.key);
        li.querySelector("span:last-child").textContent = "✓ Uploaded";
        li.querySelector("span:last-child").className = "shrink-0 text-[var(--color-secondary)]";
      } catch (e) {
        li.querySelector("span:last-child").textContent = "✗ Failed";
        li.querySelector("span:last-child").className = "shrink-0 text-[var(--color-danger)]";
      }
    }
  }

  document.getElementById("request-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    submitError.classList.add("hidden");

    const chiefComplaint = document.getElementById("chief-complaint").value.trim();
    if (!chiefComplaint) {
      submitError.textContent = "Please enter your chief complaint";
      submitError.classList.remove("hidden");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    try {
      const res = await fetch("/api/consultation", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          doctorId,
          chiefComplaint,
          symptoms: document.getElementById("symptoms").value.trim() || undefined,
          durationOfSymptoms: document.getElementById("duration").value.trim() || undefined,
          existingConditions: document.getElementById("existing").value.trim() || undefined,
          currentMedications: document.getElementById("medications").value.trim() || undefined,
          attachedFiles: uploadedKeys.length > 0 ? uploadedKeys : undefined,
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? "Failed to send request");
      window.location.href = "/dashboard/patient";
    } catch (err) {
      submitError.textContent = err.message;
      submitError.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Consultation Request";
    }
  });
</script>
