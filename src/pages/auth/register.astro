---
import AuthLayout from "../../layouts/AuthLayout.astro";

// Must have a valid session (just verified OTP)
const session = Astro.cookies.get("session");
if (!session?.value) return Astro.redirect("/auth/login");

const res = await fetch(`${Astro.url.origin}/api/auth/me`, {
  headers: { cookie: `session=${session.value}` },
});
const data = await res.json<{ user: { role: string } | null }>();
// Already registered → go to dashboard
if (data.user?.role) return Astro.redirect(`/dashboard/${data.user.role}`);
---

<AuthLayout title="Create your account — MedConnect">
  <div class="bg-white rounded-2xl border border-[var(--color-border)] shadow-sm p-8">
    <h1 class="text-2xl font-bold mb-1">Create your account</h1>
    <p class="text-[var(--color-muted)] text-sm mb-8">Choose how you want to use MedConnect</p>

    <!-- Role selection -->
    <div id="step-role">
      <div class="grid grid-cols-2 gap-4 mb-6">
        <button
          type="button"
          data-role="patient"
          class="role-card flex flex-col items-center gap-3 p-5 rounded-xl border-2 border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          <span class="font-semibold text-sm">I'm a Patient</span>
          <span class="text-xs text-[var(--color-muted)] text-center leading-snug">Find doctors and get consultations</span>
        </button>
        <button
          type="button"
          data-role="doctor"
          class="role-card flex flex-col items-center gap-3 p-5 rounded-xl border-2 border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span class="font-semibold text-sm">I'm a Doctor</span>
          <span class="text-xs text-[var(--color-muted)] text-center leading-snug">Register your practice, consult patients</span>
        </button>
      </div>
      <p id="role-error" class="text-xs text-[var(--color-danger)] mb-3 hidden">Please select a role to continue</p>
    </div>

    <!-- Basic profile form -->
    <div id="step-profile" class="hidden">
      <button type="button" id="back-to-role" class="flex items-center gap-1 text-sm text-[var(--color-primary)] mb-5 hover:underline">
        ← Back
      </button>
      <form id="profile-form" novalidate>
        <input type="hidden" id="selected-role" name="role" />
        <div class="mb-4">
          <label for="name" class="block text-sm font-medium mb-1.5">Full name</label>
          <input
            id="name"
            name="name"
            type="text"
            placeholder="Dr. Priya Sharma"
            autocomplete="name"
            required
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent"
          />
          <p id="name-error" class="text-xs text-[var(--color-danger)] mt-1 hidden"></p>
        </div>

        <!-- Doctor-only fields -->
        <div id="doctor-fields" class="hidden space-y-4">
          <div>
            <label for="specialization" class="block text-sm font-medium mb-1.5">Specialization</label>
            <input id="specialization" name="specialization" type="text" placeholder="e.g. General Physician, Cardiologist"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
          </div>
          <div>
            <label for="qualification" class="block text-sm font-medium mb-1.5">Qualification</label>
            <input id="qualification" name="qualification" type="text" placeholder="e.g. MBBS, MD"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="reg-number" class="block text-sm font-medium mb-1.5">Reg. number</label>
              <input id="reg-number" name="registrationNumber" type="text" placeholder="MH-12345"
                class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
            </div>
            <div>
              <label for="reg-council" class="block text-sm font-medium mb-1.5">Council</label>
              <input id="reg-council" name="registrationCouncil" type="text" placeholder="Maharashtra MC"
                class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="city" class="block text-sm font-medium mb-1.5">City</label>
              <input id="city" name="city" type="text" placeholder="Mumbai"
                class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
            </div>
            <div>
              <label for="state" class="block text-sm font-medium mb-1.5">State</label>
              <input id="state" name="state" type="text" placeholder="Maharashtra"
                class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent" />
            </div>
          </div>
        </div>

        <p id="form-error" class="text-xs text-[var(--color-danger)] mt-2 mb-3 hidden"></p>

        <button
          type="submit"
          id="submit-btn"
          class="w-full mt-4 py-2.5 rounded-lg bg-[var(--color-primary)] text-white font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors disabled:opacity-60"
        >
          Create account
        </button>
      </form>
    </div>
  </div>
</AuthLayout>

<script>
  let selectedRole: "doctor" | "patient" | "" = "";
  const stepRole = document.getElementById("step-role")!;
  const stepProfile = document.getElementById("step-profile")!;
  const doctorFields = document.getElementById("doctor-fields")!;
  const selectedRoleInput = document.getElementById("selected-role") as HTMLInputElement;
  const roleError = document.getElementById("role-error")!;
  const formError = document.getElementById("form-error")!;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  document.querySelectorAll<HTMLButtonElement>(".role-card").forEach((card) => {
    card.addEventListener("click", () => {
      selectedRole = card.dataset.role as "doctor" | "patient";
      selectedRoleInput.value = selectedRole;
      roleError.classList.add("hidden");

      // Highlight selection
      document.querySelectorAll(".role-card").forEach((c) =>
        c.classList.remove("border-[var(--color-primary)]", "bg-blue-50")
      );
      card.classList.add("border-[var(--color-primary)]", "bg-blue-50");

      // Show profile form after brief delay
      setTimeout(() => {
        stepRole.classList.add("hidden");
        stepProfile.classList.remove("hidden");
        if (selectedRole === "doctor") {
          doctorFields.classList.remove("hidden");
          submitBtn.textContent = "Create doctor account";
        } else {
          doctorFields.classList.add("hidden");
          submitBtn.textContent = "Create patient account";
        }
        (document.getElementById("name") as HTMLInputElement).focus();
      }, 150);
    });
  });

  document.getElementById("back-to-role")!.addEventListener("click", () => {
    stepProfile.classList.add("hidden");
    stepRole.classList.remove("hidden");
  });

  document.getElementById("profile-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    formError.classList.add("hidden");

    const name = (document.getElementById("name") as HTMLInputElement).value.trim();
    if (name.length < 2) {
      const el = document.getElementById("name-error")!;
      el.textContent = "Please enter your full name";
      el.classList.remove("hidden");
      return;
    }

    const body: Record<string, string> = { name, role: selectedRole };
    if (selectedRole === "doctor") {
      body.specialization = (document.getElementById("specialization") as HTMLInputElement).value.trim();
      body.qualification = (document.getElementById("qualification") as HTMLInputElement).value.trim();
      body.registrationNumber = (document.getElementById("reg-number") as HTMLInputElement).value.trim();
      body.registrationCouncil = (document.getElementById("reg-council") as HTMLInputElement).value.trim();
      body.city = (document.getElementById("city") as HTMLInputElement).value.trim();
      body.state = (document.getElementById("state") as HTMLInputElement).value.trim();

      if (!body.specialization || !body.qualification || !body.registrationNumber || !body.registrationCouncil) {
        formError.textContent = "Please fill all required doctor fields";
        formError.classList.remove("hidden");
        return;
      }
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Creating account…";

    try {
      const res = await fetch("/api/auth/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      const data = await res.json<{ error?: string; role?: string }>();
      if (!res.ok) throw new Error(data.error ?? "Registration failed");
      window.location.href = `/dashboard/${data.role}`;
    } catch (err: unknown) {
      formError.textContent = err instanceof Error ? err.message : "Registration failed";
      formError.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Create account";
    }
  });
</script>
