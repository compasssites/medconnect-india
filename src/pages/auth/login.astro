---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { getSessionUser } from "../../lib/auth/session";
import { getTurnstileClientConfig } from "../../lib/auth/turnstile";

Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate");
Astro.response.headers.set("Pragma", "no-cache");
Astro.response.headers.set("Expires", "0");

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;

if (env && sessionCookie) {
  const user = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
  if (user?.role) {
    return Astro.redirect(`/dashboard/${user.role}`);
  }
}

const turnstile = getTurnstileClientConfig(env);
---

<AuthLayout title="Sign in — MedConnect">
  <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
    <h1 class="mb-1 text-2xl font-bold">Welcome back</h1>
    <p class="mb-8 text-sm text-[var(--color-muted)]">Sign in with your email and password.</p>

    <form id="login-form" novalidate>
      <div class="mb-4">
        <label for="email" class="mb-1.5 block text-sm font-medium">Email address</label>
        <input
          id="email"
          type="email"
          placeholder="you@example.com"
          autocomplete="email"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>

      <div class="mb-3">
        <div class="mb-1.5 flex items-center justify-between gap-3">
          <label for="password" class="block text-sm font-medium">Password</label>
          <a href="/auth/forgot-password" class="text-xs text-[var(--color-primary)] hover:underline">Forgot password?</a>
        </div>
        <input
          id="password"
          type="password"
          placeholder="Enter your password"
          autocomplete="current-password"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>

      {turnstile.enabled && (
        <>
          <div class="mb-4">
            <label class="mb-1.5 block text-sm font-medium">Security check</label>
            <div id="login-turnstile" class="min-h-[68px] rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-2"></div>
          </div>
          <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" defer></script>
        </>
      )}

      <p id="form-error" class="mb-3 hidden text-xs text-[var(--color-danger)]"></p>

      <button
        type="submit"
        id="submit-btn"
        class="w-full rounded-lg bg-[var(--color-primary)] py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-primary-dark)] disabled:opacity-60"
      >
        Sign in
      </button>
    </form>

    <div class="mt-6 space-y-2 text-center text-xs text-[var(--color-muted)]">
      <p>New here? <a href="/auth/register" class="text-[var(--color-primary)] hover:underline">Create your account</a></p>
      <p>Already had a code-only account? Use <a href="/auth/forgot-password" class="text-[var(--color-primary)] hover:underline">Forgot password</a> once to set your password.</p>
    </div>
  </div>
</AuthLayout>

<script define:vars={{ turnstileEnabled: turnstile.enabled, turnstileSiteKey: turnstile.siteKey }}>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const formError = document.getElementById("form-error") as HTMLParagraphElement;
  let turnstileWidgetId: string | null = null;

  function getTurnstileApi() {
    return (window as Window & {
      turnstile?: {
        render: (container: string, options: Record<string, unknown>) => string;
        getResponse: (widgetId: string) => string;
        reset: (widgetId: string) => void;
      };
    }).turnstile;
  }

  function ensureTurnstileWidget() {
    if (!turnstileEnabled || turnstileWidgetId) return;
    const api = getTurnstileApi();
    if (!api) return;
    turnstileWidgetId = api.render("#login-turnstile", {
      sitekey: turnstileSiteKey,
      action: "login",
      theme: "light",
    });
  }

  function readTurnstileToken() {
    if (!turnstileEnabled || !turnstileWidgetId) return "";
    return getTurnstileApi()?.getResponse(turnstileWidgetId) ?? "";
  }

  function resetTurnstile() {
    if (!turnstileEnabled || !turnstileWidgetId) return;
    getTurnstileApi()?.reset(turnstileWidgetId);
  }

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    formError.classList.add("hidden");

    const email = emailInput.value.trim().toLowerCase();
    const password = passwordInput.value;

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      formError.textContent = "Enter a valid email address";
      formError.classList.remove("hidden");
      return;
    }

    if (password.length < 8) {
      formError.textContent = "Enter your password";
      formError.classList.remove("hidden");
      return;
    }

    const turnstileToken = readTurnstileToken();
    if (turnstileEnabled && !turnstileToken) {
      formError.textContent = "Please complete the security check";
      formError.classList.remove("hidden");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Signing in…";

    try {
      const response = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password, turnstileToken }),
      });

      const data = await response.json<{ error?: string; user?: { role: string } }>();
      if (!response.ok) throw new Error(data.error ?? "Sign-in failed");
      window.location.href = `/dashboard/${data.user?.role ?? ""}`;
    } catch (error: unknown) {
      formError.textContent = error instanceof Error ? error.message : "Sign-in failed";
      formError.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Sign in";
      resetTurnstile();
    }
  });

  if (turnstileEnabled) {
    const waitForTurnstile = window.setInterval(() => {
      if (getTurnstileApi()) {
        ensureTurnstileWidget();
        window.clearInterval(waitForTurnstile);
      }
    }, 150);
    window.addEventListener("load", ensureTurnstileWidget, { once: true });
  }
</script>
