---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { getSessionUser } from "../../lib/auth/session";
import { getTurnstileClientConfig } from "../../lib/auth/turnstile";

Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate");
Astro.response.headers.set("Pragma", "no-cache");
Astro.response.headers.set("Expires", "0");

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;

if (env && sessionCookie) {
  const user = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
  if (user?.role) {
    return Astro.redirect(`/dashboard/${user.role}`);
  }
}

const turnstile = getTurnstileClientConfig(env);
const emailParam = Astro.url.searchParams.get("email")?.trim().toLowerCase() ?? "";
const mode = Astro.url.searchParams.get("step") === "code" && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailParam) ? "code" : "email";
---

<AuthLayout title="Reset password — MedConnect">
  <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
    <a href="/auth/login" class="mb-5 inline-flex items-center gap-1 text-sm text-[var(--color-primary)] hover:underline">← Back to sign in</a>
    <h1 class="mb-1 text-2xl font-bold">Reset your password</h1>
    <p class="mb-8 text-sm text-[var(--color-muted)]">We’ll email you a verification code so you can set a new password.</p>

    <div id="step-email" class:list={{ hidden: mode === "code" }}>
      <div class="mb-4">
        <label for="email" class="mb-1.5 block text-sm font-medium">Email address</label>
        <input
          id="email"
          type="email"
          value={mode === "email" ? emailParam : ""}
          placeholder="you@example.com"
          autocomplete="email"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>
      <p id="email-error" class="mb-3 hidden text-xs text-[var(--color-danger)]"></p>
      <button
        type="button"
        id="send-btn"
        class="w-full rounded-lg bg-[var(--color-primary)] py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-primary-dark)] disabled:opacity-60"
      >
        Email code
      </button>
    </div>

    <div id="step-reset" class:list={{ hidden: mode !== "code" }}>
      <p class="mb-3 text-sm text-[var(--color-muted)]">
        Enter the code sent to <span id="email-display" class="font-medium text-[var(--color-text)]">{emailParam}</span>.
        <button type="button" id="change-email" class="ml-1 text-[var(--color-primary)] underline">Change</button>
      </p>

      <div id="dev-code-banner" class="mb-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3">
        <p class="mb-0.5 text-xs font-medium text-amber-700">Email sending not configured — your code:</p>
        <p id="dev-code-value" class="text-2xl font-mono font-bold tracking-widest text-amber-900"></p>
      </div>

      <div class="mb-4">
        <label for="code" class="mb-1.5 block text-sm font-medium">6-digit code</label>
        <input
          id="code"
          type="text"
          inputmode="numeric"
          autocomplete="one-time-code"
          maxlength="12"
          placeholder="123456"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm font-mono tracking-[0.4em] focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>

      <div class="mb-4">
        <label for="password" class="mb-1.5 block text-sm font-medium">New password</label>
        <input
          id="password"
          type="password"
          autocomplete="new-password"
          placeholder="Use at least 8 characters"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>

      <div class="mb-4">
        <label for="confirm-password" class="mb-1.5 block text-sm font-medium">Confirm password</label>
        <input
          id="confirm-password"
          type="password"
          autocomplete="new-password"
          placeholder="Re-enter your password"
          class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
        />
      </div>

      <p id="reset-error" class="mb-3 hidden text-xs text-[var(--color-danger)]"></p>

      <button
        type="button"
        id="reset-btn"
        class="w-full rounded-lg bg-[var(--color-primary)] py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-primary-dark)] disabled:opacity-60"
      >
        Set new password
      </button>

      <button
        type="button"
        id="resend-btn"
        class="mt-2 w-full py-2 text-sm text-[var(--color-primary)] hover:underline disabled:opacity-50"
      >
        Resend code
      </button>
    </div>

    {turnstile.enabled && (
      <>
        <div class="mt-6">
          <p class="mb-2 text-sm font-medium">Security check</p>
          <div id="forgot-password-turnstile" class="min-h-[68px] rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] p-2"></div>
          <p class="mt-2 text-xs text-[var(--color-muted)]">Complete this before sending or resending a code.</p>
        </div>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" defer></script>
      </>
    )}
  </div>
</AuthLayout>

<script define:vars={{ turnstileEnabled: turnstile.enabled, turnstileSiteKey: turnstile.siteKey, initialMode: mode, initialEmail: emailParam }}>
  const stepEmail = document.getElementById("step-email");
  const stepReset = document.getElementById("step-reset");
  const emailInput = document.getElementById("email");
  const codeInput = document.getElementById("code");
  const passwordInput = document.getElementById("password");
  const confirmPasswordInput = document.getElementById("confirm-password");
  const emailDisplay = document.getElementById("email-display");
  const emailError = document.getElementById("email-error");
  const resetError = document.getElementById("reset-error");
  const sendBtn = document.getElementById("send-btn");
  const resetBtn = document.getElementById("reset-btn");
  const resendBtn = document.getElementById("resend-btn");
  const changeEmail = document.getElementById("change-email");
  const devCodeBanner = document.getElementById("dev-code-banner");
  const devCodeValue = document.getElementById("dev-code-value");

  let currentEmail = initialEmail;
  let turnstileWidgetId = null;

  function getTurnstileApi() {
    return window.turnstile;
  }

  function ensureTurnstileWidget() {
    if (!turnstileEnabled || turnstileWidgetId) return;
    const api = getTurnstileApi();
    if (!api) return;
    turnstileWidgetId = api.render("#forgot-password-turnstile", {
      sitekey: turnstileSiteKey,
      action: "reset-password",
      theme: "light",
    });
  }

  function readTurnstileToken() {
    if (!turnstileEnabled || !turnstileWidgetId) return "";
    return getTurnstileApi()?.getResponse(turnstileWidgetId) ?? "";
  }

  function resetTurnstile() {
    if (!turnstileEnabled || !turnstileWidgetId) return;
    getTurnstileApi()?.reset(turnstileWidgetId);
  }

  function showError(target, message) {
    if (!target) return;
    target.textContent = message;
    target.classList.remove("hidden");
  }

  function clearError(target) {
    if (!target) return;
    target.classList.add("hidden");
  }

  function getErrorMessage(value, fallback) {
    if (typeof value === "string" && value.trim()) return value;
    if (value && typeof value === "object") {
      if (typeof value.message === "string" && value.message.trim()) return value.message;
      if (Array.isArray(value.issues) && value.issues.length > 0) {
        const firstIssue = value.issues[0];
        if (firstIssue && typeof firstIssue.message === "string" && firstIssue.message.trim()) {
          return firstIssue.message;
        }
      }
      if (Array.isArray(value.error) && value.error.length > 0) {
        const firstError = value.error[0];
        if (firstError && typeof firstError.message === "string" && firstError.message.trim()) {
          return firstError.message;
        }
      }
    }
    return fallback;
  }

  function showResetStep(email, devCode) {
    currentEmail = email;
    emailDisplay.textContent = email;
    stepEmail.classList.add("hidden");
    stepReset.classList.remove("hidden");
    if (devCode) {
      devCodeValue.textContent = devCode;
      devCodeBanner.classList.remove("hidden");
      if (codeInput) codeInput.value = devCode;
    } else {
      devCodeBanner.classList.add("hidden");
      if (codeInput) codeInput.value = "";
    }
    window.history.replaceState({}, "", `/auth/forgot-password?step=code&email=${encodeURIComponent(email)}`);
    codeInput?.focus();
  }

  function showEmailStep() {
    stepReset.classList.add("hidden");
    stepEmail.classList.remove("hidden");
    clearError(resetError);
    emailInput.focus();
    window.history.replaceState({}, "", "/auth/forgot-password");
  }

  async function sendCode(email) {
    clearError(emailError);
    clearError(resetError);

    const turnstileToken = readTurnstileToken();
    if (turnstileEnabled && !turnstileToken) {
      showError(emailError, "Please complete the security check");
      return;
    }

    sendBtn.disabled = true;
    sendBtn.textContent = "Sending…";

    try {
      const response = await fetch("/api/auth/send-reset-code", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, turnstileToken }),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(getErrorMessage(data?.error ?? data, "Failed to send code"));
      showResetStep(email, data.code);
    } catch (error) {
      showError(emailError, getErrorMessage(error, "Failed to send code"));
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = "Email code";
      resetTurnstile();
    }
  }

  async function handleSendCode() {
    const email = emailInput.value.trim().toLowerCase();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError(emailError, "Enter a valid email address");
      return;
    }

    await sendCode(email);
  }

  async function handleResetPassword() {
    clearError(resetError);

    const code = codeInput?.value.replace(/\D/g, "").slice(0, 6) ?? "";
    const password = passwordInput?.value ?? "";
    const confirmPassword = confirmPasswordInput?.value ?? "";
    if (codeInput) codeInput.value = code;

    if (!/^\d{6}$/.test(code)) {
      showError(resetError, "Enter the 6-digit code");
      return;
    }

    if (password.length < 8 || !/[A-Za-z]/.test(password) || !/\d/.test(password)) {
      showError(resetError, "Use at least 8 characters with letters and numbers");
      return;
    }

    if (password !== confirmPassword) {
      showError(resetError, "Passwords do not match");
      return;
    }

    if (!resetBtn) return;
    resetBtn.disabled = true;
    resetBtn.textContent = "Saving…";

    try {
      const response = await fetch("/api/auth/reset-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email: currentEmail,
          code,
          password,
        }),
      });

      const data = await response.json();
      if (!response.ok) throw new Error(getErrorMessage(data?.error ?? data, "Failed to reset password"));
      window.location.href = `/dashboard/${data.user?.role ?? ""}`;
    } catch (error) {
      showError(resetError, getErrorMessage(error, "Failed to reset password"));
      resetBtn.disabled = false;
      resetBtn.textContent = "Set new password";
    }
  }

  sendBtn.addEventListener("click", () => {
    void handleSendCode();
  });

  resetBtn?.addEventListener("click", () => {
    void handleResetPassword();
  });

  resendBtn?.addEventListener("click", () => {
    void sendCode(currentEmail);
  });

  emailInput.addEventListener("keydown", (event) => {
    if (event.key === "Enter") {
      event.preventDefault();
      void handleSendCode();
    }
  });

  codeInput?.addEventListener("input", () => {
    const digits = codeInput.value.replace(/\D/g, "").slice(0, 6);
    if (digits !== codeInput.value) codeInput.value = digits;
  });

  codeInput?.addEventListener("paste", (event) => {
    event.preventDefault();
    const pasted = event.clipboardData?.getData("text") ?? "";
    codeInput.value = pasted.replace(/\D/g, "").slice(0, 6);
  });

  changeEmail?.addEventListener("click", () => {
    if (codeInput) codeInput.value = "";
    if (passwordInput) passwordInput.value = "";
    if (confirmPasswordInput) confirmPasswordInput.value = "";
    showEmailStep();
    resetTurnstile();
  });

  if (initialMode === "code" && currentEmail) {
    showResetStep(currentEmail);
  }

  if (turnstileEnabled) {
    const waitForTurnstile = window.setInterval(() => {
      if (getTurnstileApi()) {
        ensureTurnstileWidget();
        window.clearInterval(waitForTurnstile);
      }
    }, 150);
    window.addEventListener("load", ensureTurnstileWidget, { once: true });
  }
</script>
