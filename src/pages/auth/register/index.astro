---
import AuthLayout from "../../../layouts/AuthLayout.astro";
import { getSession, getSessionUser, updateSessionUserId } from "../../../lib/auth/session";
import { ensureAdminUser, getDoctorProfileByUserId, hasAdminAccount, listApprovedDoctors } from "../../../lib/db/queries";

Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate");
Astro.response.headers.set("Pragma", "no-cache");
Astro.response.headers.set("Expires", "0");

const env = (Astro.locals as App.Locals).runtime?.env;
if (!env) return Astro.redirect("/auth/login");

const sessionCookie = Astro.cookies.get("session")?.value;
const sessionData = sessionCookie ? await getSession(env.SESSIONS, sessionCookie) : null;
const hasPendingRegistration = Boolean(sessionData && !sessionData.userId);

if (sessionData?.userId && sessionCookie) {
  const existingUser = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
  if (existingUser?.role === "doctor") {
    const existingDoctorProfile = await getDoctorProfileByUserId(env.DB, existingUser.id);
    if (!existingDoctorProfile) return Astro.redirect("/auth/register/doctor?resume=1");
  }
  if (existingUser?.role) return Astro.redirect("/dashboard");
}

const adminEmail = env.ADMIN_EMAIL?.trim().toLowerCase();
if (hasPendingRegistration && sessionCookie && adminEmail && sessionData?.email === adminEmail) {
  const adminUser = await ensureAdminUser(env.DB, sessionData.email);
  if (adminUser) {
    await updateSessionUserId(env.SESSIONS, sessionCookie, adminUser.id);
    return Astro.redirect("/dashboard/admin");
  }
}

const approvedDoctors = await listApprovedDoctors(env.DB);
const adminExists = await hasAdminAccount(env.DB);
---

<AuthLayout title="Create your account — MedConnect">
  <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
    <a href="/auth/login" class="mb-5 inline-flex items-center gap-1 text-sm text-[var(--color-primary)] hover:underline">← Back to sign in</a>
    <h1 class="mb-1 text-2xl font-bold">Create your account</h1>
    <p class="mb-2 text-sm text-[var(--color-muted)]">
      Choose the account type that fits you. Each flow now verifies your email and sets your password separately.
    </p>

    {hasPendingRegistration && sessionData ? (
      <div class="mb-6 rounded-xl border border-emerald-100 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
        Email already verified for <span class="font-semibold">{sessionData.email}</span>. Continue with the account type you want to finish.
      </div>
    ) : null}

    <div class="space-y-4">
      <a
        href="/auth/register/patient"
        class="block rounded-2xl border border-[var(--color-border)] px-5 py-5 transition-colors hover:border-[var(--color-primary)] hover:bg-blue-50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-base font-semibold">Patient registration</p>
            <p class="mt-1 text-sm text-[var(--color-muted)]">Verify your email, set your password, and start requesting consultations.</p>
          </div>
          <span class="shrink-0 rounded-full bg-[var(--color-bg)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]">
            Patient
          </span>
        </div>
      </a>

      <a
        href="/auth/register/doctor"
        class="block rounded-2xl border border-[var(--color-border)] px-5 py-5 transition-colors hover:border-[var(--color-secondary)] hover:bg-emerald-50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-base font-semibold">Doctor registration</p>
            <p class="mt-1 text-sm text-[var(--color-muted)]">Verify your email, set your password, and complete your doctor profile details.</p>
          </div>
          <span class="shrink-0 rounded-full bg-[var(--color-bg)] px-3 py-1 text-xs font-semibold text-[var(--color-secondary)]">
            Doctor
          </span>
        </div>
      </a>
    </div>

    <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-xs text-[var(--color-muted)]">
      {approvedDoctors.length > 0
        ? "Doctor registrations go through approval by an existing approved doctor before they appear publicly."
        : adminExists
          ? "Doctor registrations go to the admin dashboard for review until approved doctors are available."
          : "The first doctor account is approved directly so the network can start."}
    </div>
  </div>
</AuthLayout>
