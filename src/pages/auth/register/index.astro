---
import AuthLayout from "../../../layouts/AuthLayout.astro";
import { getSession, getSessionUser, updateSessionUserId } from "../../../lib/auth/session";
import { ensureAdminUser, hasAdminAccount, listApprovedDoctors } from "../../../lib/db/queries";

const session = Astro.cookies.get("session");
if (!session?.value) return Astro.redirect("/auth/login");

const env = (Astro.locals as App.Locals).runtime?.env;
if (!env) return Astro.redirect("/auth/login");

const sessionData = await getSession(env.SESSIONS, session.value);
if (!sessionData) return Astro.redirect("/auth/login");

if (sessionData.userId) {
  const existingUser = await getSessionUser(env.SESSIONS, env.DB, session.value);
  if (existingUser?.role) return Astro.redirect(`/dashboard/${existingUser.role}`);
}

const adminEmail = env.ADMIN_EMAIL?.trim().toLowerCase();
if (!sessionData.userId && adminEmail && sessionData.email === adminEmail) {
  const adminUser = await ensureAdminUser(env.DB, sessionData.email);
  if (adminUser) {
    await updateSessionUserId(env.SESSIONS, session.value, adminUser.id);
    return Astro.redirect("/dashboard/admin");
  }
}

const approvedDoctors = await listApprovedDoctors(env.DB);
const adminExists = await hasAdminAccount(env.DB);
---

<AuthLayout title="Choose your account — MedConnect">
  <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
    <h1 class="mb-1 text-2xl font-bold">Create your account</h1>
    <p class="mb-2 text-sm text-[var(--color-muted)]">Signed in as {sessionData.email}</p>
    <p class="mb-8 text-sm text-[var(--color-muted)]">Choose the registration flow that matches how you’ll use MedConnect.</p>

    <div class="space-y-4">
      <a
        href="/auth/register/patient"
        class="block rounded-2xl border border-[var(--color-border)] px-5 py-5 transition-colors hover:border-[var(--color-primary)] hover:bg-blue-50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-base font-semibold">Register as a patient</p>
            <p class="mt-1 text-sm text-[var(--color-muted)]">Set up a patient account to find doctors and request consultations.</p>
          </div>
          <span class="shrink-0 rounded-full bg-[var(--color-bg)] px-3 py-1 text-xs font-semibold text-[var(--color-primary)]">
            Patient
          </span>
        </div>
      </a>

      <a
        href="/auth/register/doctor"
        class="block rounded-2xl border border-[var(--color-border)] px-5 py-5 transition-colors hover:border-[var(--color-secondary)] hover:bg-emerald-50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-base font-semibold">Register as a doctor</p>
            <p class="mt-1 text-sm text-[var(--color-muted)]">Share your qualifications, medical registration details, and consultation profile.</p>
          </div>
          <span class="shrink-0 rounded-full bg-[var(--color-bg)] px-3 py-1 text-xs font-semibold text-[var(--color-secondary)]">
            Doctor
          </span>
        </div>
      </a>
    </div>

    <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-xs text-[var(--color-muted)]">
      {approvedDoctors.length > 0
        ? "Doctor registrations need approval from an existing approved doctor before they become public."
        : adminExists
          ? "Doctor registrations will go to the admin dashboard for review until approved doctors are available."
          : "The first doctor account will be approved directly so the network can get started."}
    </div>
  </div>
</AuthLayout>
