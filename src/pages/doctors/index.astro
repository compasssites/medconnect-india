---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { searchDoctors } from "../../lib/db/queries";
import { getSessionUser } from "../../lib/auth/session";

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;
const currentUser = env && sessionCookie ? await getSessionUser(env.SESSIONS, env.DB, sessionCookie) : null;
const dashboardHref =
  currentUser?.role === "admin"
    ? "/dashboard/admin"
    : currentUser?.role === "doctor"
      ? "/dashboard/doctor"
      : currentUser?.role === "patient"
        ? "/dashboard/patient"
        : null;
const dashboardLabel =
  currentUser?.role === "admin" ? "Back to admin dashboard" : currentUser ? "Back to dashboard" : null;

const q = Astro.url.searchParams;
const specialization = q.get("specialization") ?? undefined;
const city = q.get("city") ?? undefined;
const state = q.get("state") ?? undefined;
const name = q.get("name") ?? undefined;
const available = q.get("available") === "1" ? true : undefined;
const mode = (q.get("mode") as "online" | "offline" | undefined) ?? undefined;
const page = Math.max(1, parseInt(q.get("page") ?? "1"));
const limit = 20;
const offset = (page - 1) * limit;

const results = env
  ? await searchDoctors(env.DB, { specialization, city, state, name, isAvailable: available, consultationMode: mode, limit, offset })
  : [];

const SPECIALIZATIONS = [
  "General Physician", "Cardiologist", "Dermatologist", "Gynaecologist",
  "Orthopaedic", "Paediatrician", "Psychiatrist", "ENT Specialist",
  "Neurologist", "Diabetologist", "Oncologist", "Urologist",
];
---

<BaseLayout title="Find Doctors — MedConnect" description="Search verified doctors across India. Consult directly, pay directly.">
  <main id="main-content">
    {dashboardHref && dashboardLabel && (
      <div class="border-b border-[var(--color-border)] bg-white">
        <div class="container flex items-center justify-between gap-3 py-3 text-sm">
          <span class="text-[var(--color-muted)]">Signed in as {currentUser?.email}</span>
          <a href={dashboardHref} class="font-medium text-[var(--color-primary)] hover:underline">
            {dashboardLabel}
          </a>
        </div>
      </div>
    )}
    <!-- Header -->
    <div class="bg-[var(--color-primary)] py-8 text-white md:py-10">
      <div class="container">
        <h1 class="mb-2 text-3xl font-bold">Find a Doctor</h1>
        <p class="text-blue-100 text-sm">Direct consultations across India — no commission, no middlemen</p>
        <!-- Search bar -->
        <form method="GET" class="mt-6 grid max-w-3xl gap-3 md:grid-cols-[minmax(0,1fr)_12rem_auto]">
          <input
            type="text"
            name="name"
            value={name ?? ""}
            placeholder="Doctor name or specialization"
            class="flex-1 px-4 py-2.5 rounded-lg bg-white text-slate-900 placeholder:text-slate-500 border border-white/40 shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-white focus:border-white"
          />
          <input
            type="text"
            name="city"
            value={city ?? ""}
            placeholder="City"
            class="w-full px-4 py-2.5 rounded-lg bg-white text-slate-900 placeholder:text-slate-500 border border-white/40 shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-white focus:border-white"
          />
          <button type="submit" class="px-6 py-2.5 rounded-lg bg-white text-[var(--color-primary)] border border-white/40 shadow-sm font-semibold text-sm hover:bg-blue-50 transition-colors">
            Search
          </button>
        </form>
      </div>
    </div>

    <div class="container py-8">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Filters sidebar -->
        <aside class="shrink-0 lg:w-56">
          <form method="GET" id="filter-form">
            <input type="hidden" name="name" value={name ?? ""} />
            <input type="hidden" name="city" value={city ?? ""} />

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            <div class="bg-white rounded-xl border border-[var(--color-border)] p-4">
              <h2 class="font-semibold text-sm mb-3">Availability</h2>
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" name="available" value="1" checked={available === true}
                  onchange="this.form.submit()"
                  class="rounded border-[var(--color-border)]" />
                Available now
              </label>
            </div>

            <div class="bg-white rounded-xl border border-[var(--color-border)] p-4">
              <h2 class="font-semibold text-sm mb-3">Mode</h2>
              {["online", "offline"].map((m) => (
                <label class="flex items-center gap-2 text-sm cursor-pointer mb-2">
                  <input type="radio" name="mode" value={m} checked={mode === m}
                    onchange="this.form.submit()"
                    class="border-[var(--color-border)]" />
                  {m.charAt(0).toUpperCase() + m.slice(1)}
                </label>
              ))}
              {mode && (
                <a href={`/doctors?name=${name ?? ""}&city=${city ?? ""}`} class="text-xs text-[var(--color-primary)] hover:underline">
                  Clear filter
                </a>
              )}
            </div>

            <div class="bg-white rounded-xl border border-[var(--color-border)] p-4 sm:col-span-2 lg:col-span-1">
              <h2 class="font-semibold text-sm mb-3">Specialization</h2>
              <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
                {SPECIALIZATIONS.map((s) => (
                  <a
                    href={`/doctors?specialization=${encodeURIComponent(s)}`}
                    class={`block text-sm px-2 py-1 rounded-md transition-colors ${specialization === s ? "bg-blue-50 text-[var(--color-primary)] font-medium" : "text-[var(--color-muted)] hover:text-[var(--color-text)]"}`}
                  >
                    {s}
                  </a>
                ))}
              </div>
            </div>
            </div>
          </form>
        </aside>

        <!-- Results -->
        <div class="flex-1 min-w-0">
          {(specialization || city || name || available || mode) && (
            <div class="flex flex-wrap items-center gap-2 mb-5 text-sm">
              <span class="text-[var(--color-muted)]">Filters:</span>
              {specialization && <span class="bg-blue-50 text-[var(--color-primary)] px-2.5 py-0.5 rounded-full font-medium">{specialization}</span>}
              {city && <span class="bg-blue-50 text-[var(--color-primary)] px-2.5 py-0.5 rounded-full font-medium">{city}</span>}
              {available && <span class="bg-green-50 text-[var(--color-secondary)] px-2.5 py-0.5 rounded-full font-medium">Available now</span>}
              {mode && <span class="bg-blue-50 text-[var(--color-primary)] px-2.5 py-0.5 rounded-full font-medium capitalize">{mode}</span>}
              <a href="/doctors" class="text-[var(--color-danger)] hover:underline ml-1">Clear all</a>
            </div>
          )}

          <p class="text-sm text-[var(--color-muted)] mb-4">
            {results.length === 0 ? "No doctors found" : `${results.length} doctor${results.length === 1 ? "" : "s"} found`}
            {city && ` in ${city}`}
          </p>

          {results.length === 0 ? (
            <div class="bg-white rounded-xl border border-[var(--color-border)] p-12 text-center">
              <p class="text-[var(--color-muted)] mb-2">No doctors match your search</p>
              <a href="/doctors" class="text-sm text-[var(--color-primary)] hover:underline">View all doctors</a>
            </div>
          ) : (
            <div class="grid gap-4 xl:grid-cols-2">
              {results.map(({ profile, user }) => (
                <a
                  href={`/doctors/${profile.slug}`}
                  class="bg-white rounded-xl border border-[var(--color-border)] p-5 hover:border-[var(--color-primary)] hover:shadow-sm transition-all group block"
                >
                  <div class="flex items-start gap-3 mb-3">
                    <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center shrink-0 text-[var(--color-primary)] font-bold text-lg">
                      {user.name.charAt(0)}
                    </div>
                    <div class="min-w-0">
                      <div class="flex items-center gap-2">
                        <h3 class="font-semibold text-sm group-hover:text-[var(--color-primary)] transition-colors truncate">{user.name}</h3>
                        {profile.isVerified && (
                          <svg class="w-4 h-4 text-[var(--color-primary)] shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                          </svg>
                        )}
                      </div>
                      <p class="text-xs text-[var(--color-muted)]">{profile.specialization} • {profile.qualification}</p>
                    </div>
                  </div>

                  <div class="flex flex-wrap gap-2 text-xs mb-3">
                    {profile.city && (
                      <span class="flex items-center gap-1 text-[var(--color-muted)]">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {profile.city}{profile.state ? `, ${profile.state}` : ""}
                      </span>
                    )}
                    {profile.experienceYears && (
                      <span class="text-[var(--color-muted)]">{profile.experienceYears}yr exp</span>
                    )}
                  </div>

                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <span class={`inline-flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full ${profile.isAvailable ? "bg-green-50 text-[var(--color-secondary)]" : "bg-gray-100 text-[var(--color-muted)]"}`}>
                        <span class={`w-1.5 h-1.5 rounded-full ${profile.isAvailable ? "bg-[var(--color-secondary)]" : "bg-gray-400"}`}></span>
                        {profile.isAvailable ? "Available" : "Unavailable"}
                      </span>
                      <span class="text-xs text-[var(--color-muted)] capitalize">{profile.consultationMode}</span>
                    </div>
                    {profile.consultationFee != null && (
                      <span class="text-sm font-semibold text-[var(--color-text)]">
                        {profile.consultationFee === 0 ? "Free" : `₹${profile.consultationFee}`}
                      </span>
                    )}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
