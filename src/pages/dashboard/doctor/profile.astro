---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { getSessionUser } from "../../../lib/auth/session";
import { getDoctorProfileByUserId } from "../../../lib/db/queries";
import { INDIAN_STATES_AND_UTS, MEDICAL_COUNCILS } from "../../../lib/constants/india";

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;
if (!sessionCookie || !env) return Astro.redirect("/auth/login");

const currentUser = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
if (!currentUser || currentUser.role !== "doctor") return Astro.redirect("/auth/login");

const profile = await getDoctorProfileByUserId(env.DB, currentUser.id);
if (!profile) return Astro.redirect("/dashboard/doctor");

const languages: string[] = profile.languages ? JSON.parse(profile.languages) : [];
const stateOptions = profile.state && !INDIAN_STATES_AND_UTS.includes(profile.state as (typeof INDIAN_STATES_AND_UTS)[number])
  ? [profile.state, ...INDIAN_STATES_AND_UTS]
  : INDIAN_STATES_AND_UTS;
const councilOptions =
  profile.registrationCouncil &&
  !MEDICAL_COUNCILS.includes(profile.registrationCouncil as (typeof MEDICAL_COUNCILS)[number])
    ? [profile.registrationCouncil, ...MEDICAL_COUNCILS]
    : MEDICAL_COUNCILS;
---

<DashboardLayout title="Edit Profile — MedConnect" role="doctor">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-xl font-bold mb-6">Edit Profile</h1>

    <form id="profile-form" class="space-y-6">
      <!-- Personal info -->
      <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 space-y-4">
        <h2 class="font-semibold">Personal Information</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium mb-1.5">Full name</label>
            <input id="name" type="text" value={currentUser.name} required
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Experience (years)</label>
            <input id="experience" type="number" min="0" value={profile.experienceYears ?? ""}
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Bio / About</label>
          <textarea id="bio" rows="3" maxlength="1000"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] resize-y"
          >{profile.bio ?? ""}</textarea>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium mb-1.5">City</label>
            <input id="city" type="text" value={profile.city ?? ""}
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">State</label>
            <select id="state"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
              <option value="">Select state</option>
              {stateOptions.map((state) => (
                <option value={state} selected={profile.state === state}>{state}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-medium mb-1.5">Registration number</label>
            <input id="registration-number" type="text" value={profile.registrationNumber}
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Medical council</label>
            <select id="registration-council"
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] bg-white text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
              <option value="">Select council</option>
              {councilOptions.map((council) => (
                <option value={council} selected={profile.registrationCouncil === council}>{council}</option>
              ))}
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Languages (comma-separated)</label>
          <input id="languages" type="text" value={languages.join(", ")} placeholder="e.g. Hindi, English, Marathi"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
      </div>

      <!-- Clinic -->
      <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 space-y-4">
        <h2 class="font-semibold">Clinic / Practice</h2>
        <div>
          <label class="block text-sm font-medium mb-1.5">Clinic name</label>
          <input id="clinic-name" type="text" value={profile.clinicName ?? ""}
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Clinic address</label>
          <textarea id="clinic-address" rows="2"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] resize-y"
          >{profile.clinicAddress ?? ""}</textarea>
        </div>
      </div>

      <!-- Consultation settings -->
      <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 space-y-4">
        <h2 class="font-semibold">Consultation Settings</h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Mode</label>
            <select id="mode" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
              {["online","offline","both"].map((m) => (
                <option value={m} selected={profile.consultationMode === m}>{m.charAt(0).toUpperCase()+m.slice(1)}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Fee (₹)</label>
            <input id="fee" type="number" min="0" value={profile.consultationFee ?? 0}
              class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Payment</label>
            <select id="payment" class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
              {["prepaid","postpaid","flexible"].map((p) => (
                <option value={p} selected={profile.paymentMode === p}>{p.charAt(0).toUpperCase()+p.slice(1)}</option>
              ))}
            </select>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">UPI ID</label>
          <input id="upi" type="text" value={profile.upiId ?? ""} placeholder="yourname@upi"
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Consultation terms</label>
          <textarea id="terms" rows="3" maxlength="2000"
            placeholder="e.g. Prescription only after payment. Video call required for first consultation."
            class="w-full px-3 py-2 rounded-lg border border-[var(--color-border)] text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] resize-y"
          >{profile.terms ?? ""}</textarea>
        </div>
      </div>

      <p id="save-error" class="text-sm text-[var(--color-danger)] hidden"></p>
      <p id="save-success" class="text-sm text-[var(--color-secondary)] hidden">Profile saved!</p>

      <div class="flex gap-3">
        <button type="submit" id="save-btn"
          class="px-6 py-2.5 rounded-xl bg-[var(--color-primary)] text-white font-semibold text-sm hover:bg-[var(--color-primary-dark)] transition-colors disabled:opacity-60">
          Save Changes
        </button>
        <a href={`/doctors/${profile.slug}`} class="px-6 py-2.5 rounded-xl border border-[var(--color-border)] text-sm font-medium text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors">
          View Profile
        </a>
      </div>
    </form>
  </div>
</DashboardLayout>

<script>
  document.getElementById("profile-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = document.getElementById("save-btn") as HTMLButtonElement;
    const err = document.getElementById("save-error")!;
    const ok = document.getElementById("save-success")!;
    err.classList.add("hidden");
    ok.classList.add("hidden");
    btn.disabled = true;
    btn.textContent = "Saving…";

    const langRaw = (document.getElementById("languages") as HTMLInputElement).value;
    const languages = langRaw.split(",").map((s) => s.trim()).filter(Boolean);

    try {
      const res = await fetch("/api/doctors/profile", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: (document.getElementById("name") as HTMLInputElement).value.trim(),
          experienceYears: parseInt((document.getElementById("experience") as HTMLInputElement).value) || undefined,
          bio: (document.getElementById("bio") as HTMLTextAreaElement).value.trim() || undefined,
          city: (document.getElementById("city") as HTMLInputElement).value.trim() || undefined,
          state: (document.getElementById("state") as HTMLSelectElement).value.trim() || undefined,
          registrationNumber: (document.getElementById("registration-number") as HTMLInputElement).value.trim() || undefined,
          registrationCouncil: (document.getElementById("registration-council") as HTMLSelectElement).value.trim() || undefined,
          languages: languages.length > 0 ? languages : undefined,
          clinicName: (document.getElementById("clinic-name") as HTMLInputElement).value.trim() || undefined,
          clinicAddress: (document.getElementById("clinic-address") as HTMLTextAreaElement).value.trim() || undefined,
          consultationMode: (document.getElementById("mode") as HTMLSelectElement).value,
          consultationFee: parseInt((document.getElementById("fee") as HTMLInputElement).value) || 0,
          paymentMode: (document.getElementById("payment") as HTMLSelectElement).value,
          upiId: (document.getElementById("upi") as HTMLInputElement).value.trim() || undefined,
          terms: (document.getElementById("terms") as HTMLTextAreaElement).value.trim() || undefined,
        }),
      });
      const data = await res.json<{ error?: string }>();
      if (!res.ok) throw new Error(data.error ?? "Save failed");
      ok.classList.remove("hidden");
    } catch (ex: unknown) {
      err.textContent = ex instanceof Error ? ex.message : "Save failed";
      err.classList.remove("hidden");
    } finally {
      btn.disabled = false;
      btn.textContent = "Save Changes";
    }
  });
</script>
