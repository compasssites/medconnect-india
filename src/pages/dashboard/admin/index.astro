---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { getSessionUser } from "../../../lib/auth/session";
import { countUsersByRole, countVerifiedDoctors, getPendingApprovalRequestsForReviewer, listAdminManagedDoctors } from "../../../lib/db/queries";
import { drizzle } from "drizzle-orm/d1";
import { eq, sql } from "drizzle-orm";
import { doctorProfiles, users } from "../../../lib/db/schema";
import { INDIAN_STATES_AND_UTS, MEDICAL_COUNCILS } from "../../../lib/constants/india";

const env = (Astro.locals as App.Locals).runtime?.env;
const sessionCookie = Astro.cookies.get("session")?.value;
if (!sessionCookie || !env) return Astro.redirect("/auth/login");

const currentUser = await getSessionUser(env.SESSIONS, env.DB, sessionCookie);
if (!currentUser || currentUser.role !== "admin") return Astro.redirect("/auth/login");

const db = drizzle(env.DB);
const q = Astro.url.searchParams;
const doctorName = q.get("doctorName")?.trim() ?? "";
const doctorSpecialization = q.get("doctorSpecialization")?.trim() ?? "";
const doctorCity = q.get("doctorCity")?.trim() ?? "";
const doctorState = q.get("doctorState")?.trim() ?? "";
const doctorMode = (q.get("doctorMode") as "online" | "offline" | "both" | null) ?? "";
const doctorAvailability = (q.get("doctorAvailability") as "all" | "available" | "unavailable" | null) ?? "all";
const doctorStatus =
  (q.get("doctorStatus") as "all" | "active" | "flagged" | "suspended" | "deleted" | null) ?? "active";
const approvalRequests = await getPendingApprovalRequestsForReviewer(env.DB);
const approvedDoctors = await countVerifiedDoctors(env.DB);
const managedDoctors = await listAdminManagedDoctors(env.DB, {
  name: doctorName || undefined,
  specialization: doctorSpecialization || undefined,
  city: doctorCity || undefined,
  state: doctorState || undefined,
  consultationMode: doctorMode || undefined,
  availability: doctorAvailability,
  status: doctorStatus,
});
const adminCount = await countUsersByRole(env.DB, "admin");
const totalUserCount =
  (await db.select({ count: sql<number>`count(*)` }).from(users).where(sql`${users.role} != 'admin'`).get())?.count ?? 0;
const patientCount =
  (await db.select({ count: sql<number>`count(*)` }).from(users).where(eq(users.role, "patient")).get())?.count ?? 0;
const incompleteDoctorCount =
  (
    await db
      .select({ count: sql<number>`count(*)` })
      .from(users)
      .leftJoin(doctorProfiles, eq(doctorProfiles.userId, users.id))
      .where(sql`${users.role} = 'doctor' AND ${doctorProfiles.userId} IS NULL`)
      .get()
  )?.count ?? 0;

const recommenderIds = [...new Set(approvalRequests.map((item) => item.request.recommendedByUserId).filter(Boolean))] as string[];
const recommenderMap: Record<string, string> = {};
for (const id of recommenderIds) {
  const user = await db.select({ name: users.name }).from(users).where(eq(users.id, id)).get();
  if (user) recommenderMap[id] = user.name;
}
---

<DashboardLayout title="Admin Dashboard — MedConnect" role="admin">
  <div class="mb-6">
    <h1 class="text-xl font-bold">Admin Dashboard</h1>
    <p class="mt-1 text-sm text-[var(--color-muted)]">Signed in as {currentUser.email}</p>
  </div>

  <div class="mb-6 grid grid-cols-2 gap-4 md:grid-cols-5">
    {[
      { label: "Total users", value: totalUserCount, color: "text-[var(--color-primary)]" },
      { label: "Admins", value: adminCount, color: "text-slate-700" },
      { label: "Patients", value: patientCount, color: "text-[var(--color-secondary)]" },
      { label: "Approved doctors", value: approvedDoctors, color: "text-blue-700" },
      { label: "Pending approvals", value: approvalRequests.length, color: "text-amber-700" },
    ].map(({ label, value, color }) => (
      <div class="rounded-xl border border-[var(--color-border)] bg-white p-4 text-center">
        <div class={`text-2xl font-bold ${color}`}>{value}</div>
        <div class="mt-1 text-xs text-[var(--color-muted)]">{label}</div>
      </div>
    ))}
  </div>

  {incompleteDoctorCount > 0 && (
    <div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      {incompleteDoctorCount} doctor account{incompleteDoctorCount === 1 ? "" : "s"} still need{incompleteDoctorCount === 1 ? "s" : ""} to finish profile setup before an approval request can appear here.
    </div>
  )}

  <div class="rounded-2xl border border-[var(--color-border)] bg-white p-5">
    <div class="mb-4 flex items-center justify-between gap-4">
      <div>
        <h2 class="font-semibold">Doctor approvals</h2>
        <p class="text-sm text-[var(--color-muted)]">Approve or reject new doctor registrations.</p>
      </div>
      <span class="rounded-full bg-[var(--color-bg)] px-3 py-1 text-sm font-semibold text-[var(--color-primary)]">
        {approvalRequests.length}
      </span>
    </div>

    {approvalRequests.length === 0 ? (
      <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-10 text-center text-sm text-[var(--color-muted)]">
        No doctor approvals are waiting right now.
      </div>
    ) : (
      <div class="space-y-3">
        {approvalRequests.map(({ request, doctor, profile }) => (
          <div class="rounded-xl border border-[var(--color-border)] p-4">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="min-w-0">
                <p class="font-semibold text-sm">{doctor.name}</p>
                <p class="mt-1 text-sm text-[var(--color-muted)]">{profile.specialization} · {profile.qualification}</p>
                <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-[var(--color-muted)]">
                  <span>Email: {doctor.email}</span>
                  {doctor.phone && <span>Phone: {doctor.phone}</span>}
                  <span>Registration: {profile.registrationNumber}</span>
                  <span>City: {profile.city ?? "—"}</span>
                  {request.recommendedByUserId && recommenderMap[request.recommendedByUserId] && (
                    <span>Recommended by: {recommenderMap[request.recommendedByUserId]}</span>
                  )}
                  <span>Requested: {new Date(request.requestedAt * 1000).toLocaleDateString("en-IN")}</span>
                </div>
              </div>
              <div class="flex gap-2 shrink-0">
                <button
                  type="button"
                  class="approval-action rounded-lg bg-[var(--color-secondary)] px-4 py-2 text-sm font-medium text-white hover:bg-[var(--color-secondary-dark)] transition-colors"
                  data-action="approve"
                  data-doctor-id={doctor.id}
                >
                  Approve
                </button>
                <button
                  type="button"
                  class="approval-action rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-danger)] hover:border-[var(--color-danger)] transition-colors"
                  data-action="reject"
                  data-doctor-id={doctor.id}
                >
                  Reject
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <div class="mt-6 rounded-2xl border border-[var(--color-border)] bg-white p-5">
    <div class="mb-4">
      <h2 class="font-semibold">Manage Doctors</h2>
    </div>

      <form method="GET" class="mb-5 flex flex-wrap items-center gap-3 xl:flex-nowrap">
        <input
          type="text"
          name="doctorName"
          value={doctorName}
          placeholder="Name"
          class="min-w-0 basis-[11rem] rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[11rem] xl:flex-none"
        />
        <input
          type="text"
          name="doctorSpecialization"
          value={doctorSpecialization}
          placeholder="Specialization"
          class="min-w-0 basis-[11rem] rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[11rem] xl:flex-none"
        />
        <input
          type="text"
          name="doctorCity"
          value={doctorCity}
          placeholder="City"
          class="min-w-0 basis-[9rem] rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[9rem] xl:flex-none"
        />
        <select
          name="doctorState"
          class="min-w-0 basis-[10rem] rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[10rem] xl:flex-none"
        >
          <option value="">All states</option>
          {INDIAN_STATES_AND_UTS.map((state) => (
            <option value={state} selected={doctorState === state}>{state}</option>
          ))}
        </select>
        <select
          name="doctorStatus"
          class="min-w-0 basis-[9rem] rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[9rem] xl:flex-none"
        >
          {[
            ["active", "Active"],
            ["flagged", "Flagged"],
            ["suspended", "Suspended"],
            ["deleted", "Deleted"],
            ["all", "All approved"],
          ].map(([value, label]) => (
            <option value={value} selected={doctorStatus === value}>{label}</option>
          ))}
        </select>
        <select
          name="doctorMode"
          class="min-w-0 basis-[9rem] rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[9rem] xl:flex-none"
        >
          <option value="">All modes</option>
          {["online", "offline", "both"].map((mode) => (
            <option value={mode} selected={doctorMode === mode}>{mode}</option>
          ))}
        </select>
        <select
          name="doctorAvailability"
          class="min-w-0 basis-[10rem] rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] xl:w-[10rem] xl:flex-none"
        >
          {[
            ["all", "Any availability"],
            ["available", "Available"],
            ["unavailable", "Unavailable"],
          ].map(([value, label]) => (
            <option value={value} selected={doctorAvailability === value}>{label}</option>
          ))}
        </select>
        <div class="flex gap-2 xl:ml-auto xl:flex-none">
          <button
            type="submit"
            class="rounded-lg bg-[var(--color-primary)] px-4 py-2 text-sm font-medium text-white hover:bg-[var(--color-primary-dark)] transition-colors"
          >
            Apply
          </button>
          <a
            href="/dashboard/admin"
            class="rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
          >
            Clear
          </a>
        </div>
      </form>

    {managedDoctors.length === 0 ? (
      <div class="rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-10 text-center text-sm text-[var(--color-muted)]">
        No approved doctor profiles match these filters.
      </div>
    ) : (
      <div class="space-y-4">
        {managedDoctors.map(({ user, profile }) => (
          <details class="rounded-xl border border-[var(--color-border)] p-4">
            <summary class="flex cursor-pointer list-none flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-sm">{user.name}</p>
                  {profile.deletedAt ? (
                    <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">Deleted</span>
                  ) : profile.isSuspended ? (
                    <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Suspended</span>
                  ) : profile.isFlagged ? (
                    <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Flagged</span>
                  ) : (
                    <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Active</span>
                  )}
                  {!profile.isAvailable && !profile.deletedAt && (
                    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">Unavailable</span>
                  )}
                </div>
                <p class="mt-1 text-sm text-[var(--color-muted)]">{profile.specialization} · {profile.qualification}</p>
                <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-[var(--color-muted)]">
                  <span>Email: {user.email}</span>
                  {user.phone && <span>Phone: {user.phone}</span>}
                  <span>Registration: {profile.registrationNumber}</span>
                  <span>Council: {profile.registrationCouncil}</span>
                  <span>Location: {profile.city ?? "—"}{profile.state ? `, ${profile.state}` : ""}</span>
                  {profile.consultationFee != null && <span>Fee: ₹{profile.consultationFee}</span>}
                </div>
                {(profile.flagReason || profile.suspensionReason || profile.deletedReason) && (
                  <p class="mt-2 text-xs text-[var(--color-muted)]">
                    {profile.deletedReason ?? profile.suspensionReason ?? profile.flagReason}
                  </p>
                )}
              </div>
              <div class="text-xs text-[var(--color-muted)]">Open to manage</div>
            </summary>

            <div class="mt-4 border-t border-[var(--color-border)] pt-4">
              <form class="doctor-edit-form grid gap-3 md:grid-cols-2" data-doctor-id={user.id}>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Full name</span>
                  <input name="name" value={user.name} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Specialization</span>
                  <input name="specialization" value={profile.specialization} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Qualification</span>
                  <input name="qualification" value={profile.qualification} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Registration number</span>
                  <input name="registrationNumber" value={profile.registrationNumber} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Medical council</span>
                  <select name="registrationCouncil" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
                    {MEDICAL_COUNCILS.map((council) => (
                      <option value={council} selected={profile.registrationCouncil === council}>{council}</option>
                    ))}
                  </select>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">City</span>
                  <input name="city" value={profile.city ?? ""} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">State</span>
                  <select name="state" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
                    <option value="">Select state</option>
                    {INDIAN_STATES_AND_UTS.map((state) => (
                      <option value={state} selected={profile.state === state}>{state}</option>
                    ))}
                  </select>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Fee (₹)</span>
                  <input name="consultationFee" type="number" min="0" value={profile.consultationFee ?? 0} class="w-full rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Mode</span>
                  <select name="consultationMode" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
                    {["online", "offline", "both"].map((mode) => (
                      <option value={mode} selected={profile.consultationMode === mode}>{mode}</option>
                    ))}
                  </select>
                </label>
                <label class="text-sm">
                  <span class="mb-1 block text-xs font-medium text-[var(--color-muted)]">Payment</span>
                  <select name="paymentMode" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]">
                    {["prepaid", "postpaid", "flexible"].map((paymentMode) => (
                      <option value={paymentMode} selected={profile.paymentMode === paymentMode}>{paymentMode}</option>
                    ))}
                  </select>
                </label>
                <label class="flex items-center gap-2 text-sm pt-6">
                  <input type="checkbox" name="isAvailable" checked={profile.isAvailable} class="rounded border-[var(--color-border)]" />
                  Available for consultation
                </label>

                <div class="md:col-span-2 flex flex-wrap gap-2">
                  <button type="submit" class="rounded-lg bg-[var(--color-primary)] px-4 py-2 text-sm font-medium text-white hover:bg-[var(--color-primary-dark)] transition-colors">
                    Save edits
                  </button>
                  <button type="button" class="doctor-admin-action rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800 hover:bg-amber-100 transition-colors" data-action={profile.isFlagged ? "unflag" : "flag"} data-doctor-id={user.id}>
                    {profile.isFlagged ? "Remove flag" : "Flag"}
                  </button>
                  <button type="button" class="doctor-admin-action rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-800 hover:bg-red-100 transition-colors" data-action={profile.isSuspended ? "unsuspend" : "suspend"} data-doctor-id={user.id}>
                    {profile.isSuspended ? "Lift suspension" : "Suspend"}
                  </button>
                  <button type="button" class="doctor-admin-action rounded-lg border border-slate-300 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-800 hover:bg-slate-100 transition-colors" data-action={profile.deletedAt ? "restore" : "delete"} data-doctor-id={user.id}>
                    {profile.deletedAt ? "Restore" : "Delete"}
                  </button>
                </div>
                <p class="doctor-manage-message hidden text-sm md:col-span-2"></p>
              </form>
            </div>
          </details>
        ))}
      </div>
    )}
  </div>
</DashboardLayout>

<script>
  const getMessageNode = (node) => node.closest(".doctor-edit-form")?.querySelector(".doctor-manage-message");
  const setMessage = (node, message, isError = false) => {
    const target = getMessageNode(node);
    if (!target) return;
    target.textContent = message;
    target.classList.remove("hidden", "text-red-600", "text-emerald-700");
    target.classList.add(isError ? "text-red-600" : "text-emerald-700");
  };

  const parseError = async (response, fallback) => {
    let payload = null;
    try {
      payload = await response.json();
    } catch {
      payload = null;
    }
    if (!response.ok) {
      throw new Error((payload && payload.error) || fallback);
    }
    return payload;
  };

  document.querySelectorAll(".approval-action").forEach((button) => {
    button.addEventListener("click", async () => {
      const doctorId = button.dataset.doctorId;
      const action = button.dataset.action;
      if (!doctorId || !action) return;

      let body = {};
      if (action === "reject") {
        const notes = window.prompt("Optional reason for rejection", "");
        body = notes ? { notes } : {};
      }

      button.disabled = true;
      try {
        const res = await fetch(`/api/doctors/approvals/${doctorId}/${action}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        await parseError(res, "Review failed");
        window.location.reload();
      } catch (error) {
        alert(error instanceof Error ? error.message : "Review failed");
        button.disabled = false;
      }
    });
  });

  document.querySelectorAll(".doctor-edit-form").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const doctorId = form.dataset.doctorId;
      if (!doctorId) return;

      const submitButton = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);
      const payload = {
        name: (formData.get("name") || "").toString().trim(),
        specialization: (formData.get("specialization") || "").toString().trim(),
        qualification: (formData.get("qualification") || "").toString().trim(),
        registrationNumber: (formData.get("registrationNumber") || "").toString().trim(),
        registrationCouncil: (formData.get("registrationCouncil") || "").toString().trim(),
        city: (formData.get("city") || "").toString().trim(),
        state: (formData.get("state") || "").toString().trim(),
        consultationFee: Number((formData.get("consultationFee") || "0").toString() || "0"),
        consultationMode: (formData.get("consultationMode") || "").toString(),
        paymentMode: (formData.get("paymentMode") || "").toString(),
        isAvailable: formData.get("isAvailable") === "on",
      };

      submitButton.disabled = true;
      setMessage(form, "Saving changes...");
      try {
        const response = await fetch(`/api/doctors/admin/${doctorId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        await parseError(response, "Could not save doctor changes");
        setMessage(form, "Doctor updated.");
        window.setTimeout(() => window.location.reload(), 500);
      } catch (error) {
        setMessage(form, error instanceof Error ? error.message : "Could not save doctor changes", true);
      } finally {
        submitButton.disabled = false;
      }
    });
  });

  document.querySelectorAll(".doctor-admin-action").forEach((button) => {
    button.addEventListener("click", async () => {
      const doctorId = button.dataset.doctorId;
      const action = button.dataset.action;
      if (!doctorId || !action) return;

      let reason = "";
      if (action === "flag" || action === "suspend" || action === "delete") {
        reason = window.prompt(`Optional reason to ${action} this doctor`, "") || "";
      }

      button.disabled = true;
      setMessage(button, "Saving...");
      try {
        const response = await fetch(`/api/doctors/admin/${doctorId}/${action}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(reason ? { reason } : {}),
        });
        await parseError(response, `Could not ${action} doctor`);
        setMessage(button, "Doctor updated.");
        window.setTimeout(() => window.location.reload(), 500);
      } catch (error) {
        setMessage(button, error instanceof Error ? error.message : `Could not ${action} doctor`, true);
        button.disabled = false;
      }
    });
  });
</script>
