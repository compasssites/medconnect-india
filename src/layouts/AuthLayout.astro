---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <main id="main-content" class="min-h-dvh flex items-center justify-center bg-[var(--color-bg)] px-4 py-12">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <a href="/" class="inline-block">
          <span class="text-2xl font-bold text-[var(--color-primary)]">MedConnect</span>
        </a>
      </div>
      <slot />
    </div>
  </main>
</BaseLayout>
