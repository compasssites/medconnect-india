{
  "name": "medconnect",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && cp .assetsignore dist/.assetsignore",
    "deploy:do": "npx wrangler deploy --config wrangler.chat-do.toml",
    "deploy:app": "npm run build && npx wrangler deploy",
    "deploy": "npm run deploy:do && npm run deploy:app",
    "preview": "astro preview",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply medconnect-db --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.4.0",
    "@astrojs/preact": "^4.1.0",
    "@hono/zod-validator": "^0.4.3",
    "astro": "^5.6.1",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.5",
    "preact": "^10.26.1",
    "ulid": "^2.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "@tailwindcss/vite": "^4.0.15",
    "drizzle-kit": "^0.30.5",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "wrangler": "^4.0.0"
  }
}
